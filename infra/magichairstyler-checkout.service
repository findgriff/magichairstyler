[Unit]
Description=Magic Hair Styler — checkout endpoint (Stripe session creator)
After=network.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/magichairstyler/backend.env
ExecStart=/usr/bin/python3 /opt/magichairstyler/checkout.py
Restart=always
RestartSec=3
User=root
Group=root
ProtectSystem=strict
NoNewPrivileges=yes
PrivateTmp=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
